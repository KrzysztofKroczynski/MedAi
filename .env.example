# LLM provider: "openai" or "deepseek"
LLM_PROVIDER=deepseek

# DeepSeek (used when LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=sk-...

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Model used for all LLM calls (extraction, Cypher generation, QA)
# deepseek default: deepseek-chat
# openai alternative: gpt-4o
MODEL=deepseek-chat

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
EXTRACTION_MAX_WORKERS=8

# Multi-agent layer
AGENT_MAX_ITERATIONS=20
# PDFS_DIR — path to PDF directory read by citation node (default: data/pdfs)
# Set automatically to /app/data/pdfs inside Docker
PDFS_DIR=data/pdfs
